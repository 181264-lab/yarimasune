                    break;

                case 'mason':
                    promptTitle.innerText = '仲間の確認';
                    const otherMasons = otherPlayers.filter(p => p.initialRole === 'mason');
                    if (otherMasons.length > 0) {
                        const mNames = otherMasons.map(m => m.name).join('、');
                        resultText.innerText = `もう一人の石工は 【 ${mNames} 】 さんです。`;
                    } else {
                        resultText.innerText = `もう一人の石工はどこかのプレイヤーか、お墓に隠れています。`;
                    }
                    resultText.classList.remove('hidden');
                    commitNightAction({ log: `${me.name} が石工の存在を確認しました。` });
                    break;

                case 'insomniac':
                    promptTitle.innerText = '不眠症の確認';
                    const curRole = ALL_ROLES[me.currentRole];
                    resultText.innerText = `朝が来る直前の、現在のあなたの役職は 【 ${curRole.name} 】 です。`;
                    resultText.classList.remove('hidden');
                    commitNightAction({ log: `${me.name} が不眠症の能力で自分の最終役職（${curRole.name}）を確認しました。` });
                    break;

                case 'villager':
                default:
                    promptTitle.innerText = '夜の行動はありません';
                    resultText.innerText = 'あなたは市民です。夜の能力はありません。静かに眠って朝に備えましょう。';
                    resultText.classList.remove('hidden');
                    commitNightAction({ log: `${me.name}（市民）は朝を待ちました。` });
                    break;
            }
        }

        function disableButtons(ids) {
            ids.forEach(id => {
                const el = typeof id === 'string' ? document.getElementById(id) : id;
                if (el) {
                    el.disabled = true;
                    el.classList.add('opacity-40');
                }
            });
        }

        // オンライン用のアクション完了確認ボタン
        document.getElementById('btn-complete-action').addEventListener('click', () => {
            if (isOfflineMode) return; // オフライン時は上のcommitNightAction内でのボタンイベント処理に委ねる
            transitionToScreen('nightTransition');
            document.getElementById('night-status-text').innerText = "行動を記録しました。他のプレイヤーの終了をお待ちください...";
        });


        // --- 3. DISCUSSION & REAL-TIME VOTING ---
        function processDiscussionPhase(data) {
            transitionToScreen('discussion');
            const gState = data.gameState;

            // 制限時間表示更新
            const min = Math.floor(gState.timerSeconds / 60);
            const sec = gState.timerSeconds % 60;
            document.getElementById('discussion-timer').innerText = 
                `${String(min).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;

            // タイマー管理 (ホスト側が毎秒カウントを送信)
            if (localTimerInterval) clearInterval(localTimerInterval);

            if (isHost && gState.timerRunning && gState.timerSeconds > 0) {
                localTimerInterval = setInterval(() => {
                    roomData.gameState.timerSeconds--;
                    if (roomData.gameState.timerSeconds <= 0) {
                        roomData.gameState.timerSeconds = 0;
                        roomData.gameState.timerRunning = false;
                        clearInterval(localTimerInterval);
                    }
                    broadcastData(roomData);
                }, 1000);
            }

            // ホストコントロール
            if (isHost) {
                document.getElementById('timer-host-controls').classList.remove('hidden');
            } else {
                document.getElementById('timer-host-controls').classList.add('hidden');
            }

            // 投票セレクトボックス
            const totalPlayers = gState.activePlayers.length;
            const votesMap = gState.votes || {};
            const castCount = Object.keys(votesMap).length;

            if (isOfflineMode) {
                // 対面プレイ時は、1台の画面に全員の投票プルダウンを一挙に表示
                document.getElementById('online-voting-input-area').classList.add('hidden');
                document.getElementById('vote-badges-outer').classList.add('hidden');
                
                const offlineVotingArea = document.getElementById('offline-voting-inputs-area');
                offlineVotingArea.classList.remove('hidden');
                offlineVotingArea.innerHTML = '<p class="text-xs font-bold text-slate-400">全員の投票先を入力してください：</p>';
                
                gState.activePlayers.forEach(voter => {
                    const voterDiv = document.createElement('div');
                    voterDiv.className = 'bg-slate-950 p-3 rounded-lg border border-slate-800 flex justify-between items-center';
                    
                    let optionsHtml = `<option value="">-- ${voter.name} の投票先 --</option>`;
                    gState.activePlayers.forEach(target => {
                        if (target.name !== voter.name) {
                            optionsHtml += `<option value="${target.name}">${target.name}</option>`;
                        }
                    });
                    optionsHtml += `<option value="peace">平和村（誰も吊らない）</option>`;

                    voterDiv.innerHTML = `
                        <span class="text-xs font-bold text-slate-300">${voter.name}</span>
                        <select class="offline-voter-select bg-slate-900 border border-slate-700 rounded text-xs py-1 px-2 text-white" data-voter="${voter.name}">
                            ${optionsHtml}
                        </select>
                    `;
                    offlineVotingArea.appendChild(voterDiv);
                });

                // セレクトボックスの変更をキャッチ
                document.querySelectorAll('.offline-voter-select').forEach(sel => {
                    // 保存されている値があれば復元
                    const currentVote = votesMap[sel.dataset.voter] || '';
                    sel.value = currentVote;

                    sel.addEventListener('change', (e) => {
                        const vName = e.target.dataset.voter;
                        roomData.gameState.votes[vName] = e.target.value;
                        
                        // 全員の投票が入ったかチェック
                        const updatedVotesCount = Object.keys(roomData.gameState.votes).filter(k => roomData.gameState.votes[k] !== "").length;
                        const revealBtn = document.getElementById('btn-reveal-results-manual');
                        
                        document.getElementById('vote-count-status').innerText = `投票完了: ${updatedVotesCount} / ${totalPlayers}名`;

                        if (updatedVotesCount === totalPlayers) {
                            revealBtn.classList.remove('hidden');
                        } else {
                            revealBtn.classList.add('hidden');
                        }
                    });
                });

                document.getElementById('vote-count-status').innerText = `投票完了: ${castCount} / ${totalPlayers}名`;
                if (castCount === totalPlayers) {
                    document.getElementById('btn-reveal-results-manual').classList.remove('hidden');
                } else {
                    document.getElementById('btn-reveal-results-manual').classList.add('hidden');
                }

            } else {
                // オンラインP2Pマルチプレイ時
                document.getElementById('online-voting-input-area').classList.remove('hidden');
                document.getElementById('vote-badges-outer').classList.remove('hidden');
                document.getElementById('offline-voting-inputs-area').classList.add('hidden');

                renderVoterTargetDropdown(data);
                document.getElementById('vote-count-status').innerText = `投票完了: ${castCount} / ${totalPlayers}名`;

                // バッジ表示
                const badgesContainer = document.getElementById('vote-status-badges');
                badgesContainer.innerHTML = '';
                gState.activePlayers.forEach(p => {
                    const hasVoted = !!votesMap[p.name];
                    const badge = document.createElement('span');
                    badge.className = `text-[10px] px-2 py-0.5 rounded font-bold ${
                        hasVoted ? 'bg-emerald-950 text-emerald-400 border border-emerald-800' : 'bg-slate-900 text-slate-500 border border-slate-800'
                    }`;
                    badge.innerText = `${p.name} ${hasVoted ? '✓' : '...'}`;
                    badgesContainer.appendChild(badge);
                });

                if (isHost && castCount === totalPlayers) {
                    document.getElementById('btn-reveal-results-manual').classList.remove('hidden');
                } else {
                    document.getElementById('btn-reveal-results-manual').classList.add('hidden');
                }
            }
        }

        // タイマースタート一時停止ボタン
        document.getElementById('btn-timer-toggle').addEventListener('click', () => {
            if (!isHost || !roomData) return;
            roomData.gameState.timerRunning = !roomData.gameState.timerRunning;
            broadcastData(roomData);
        });

        // 投票先の選択リスト生成
        let lastVoterHash = '';
        function renderVoterTargetDropdown(data) {
            const gState = data.gameState;
            const me = gState.activePlayers.find(p => p.peerId === (myPeer ? myPeer.id : ''));
            if (!me) return;

            const targets = gState.activePlayers.filter(p => p.name !== me.name);
            const hash = targets.map(t => t.name).join(',');
            
            if (lastVoterHash === hash) return; 
            lastVoterHash = hash;

            const selector = document.getElementById('my-vote-selector');
            selector.innerHTML = `<option value="">-- 投票先を選択 --</option>`;
            
            targets.forEach(t => {
                selector.innerHTML += `<option value="${t.name}">${t.name}</option>`;
            });
            selector.innerHTML += `<option value="peace">平和村（人狼はいない・誰も追放しない）</option>`;
        }

        // 投票ボタン送信（オンライン専用）
        document.getElementById('btn-cast-vote').addEventListener('click', (e) => {
            const sel = document.getElementById('my-vote-selector');
            const target = sel.value;
            if (!target) {
                showModal('投票エラー', '投票する対象を選択してください。');
                return;
            }

            if (isHost) {
                roomData.gameState.votes[myNickname] = target;
                broadcastData(roomData);
            } else {
                hostConnection.send({
                    type: 'CAST_VOTE',
                    payload: { voterName: myNickname, targetName: target }
                });
            }

            e.target.disabled = true;
            e.target.innerText = "投票しました！";
            e.target.className = "w-full py-2.5 bg-emerald-700 text-emerald-300 text-xs font-bold rounded-lg transition opacity-60";
            sel.disabled = true;
        });

        // ホストによる結果集計処理 (オンライン/オフライン共用)
        document.getElementById('btn-reveal-results-manual').addEventListener('click', () => {
            if (!isHost || !roomData) return;

            const gState = roomData.gameState;
            const tally = {};
            gState.activePlayers.forEach(p => tally[p.name] = 0);
            tally['peace'] = 0;

            Object.values(gState.votes).forEach(vote => {
                if (vote) tally[vote] = (tally[vote] || 0) + 1;
            });

            let maxVotes = 0;
            let executed = [];

            Object.keys(tally).forEach(name => {
                if (tally[name] > maxVotes) {
                    maxVotes = tally[name];
                    executed = [name];
                } else if (tally[name] === maxVotes && maxVotes > 0) {
                    executed.push(name);
                }
            });

            // 1票ずつの同票、または平和処刑
            const isTieOfOne = maxVotes === 1;
            if (isTieOfOne) {
                executed = [];
            }

            const activeWerewolves = gState.activePlayers.filter(p => p.currentRole === 'wolf');
            const werewolvesExist = activeWerewolves.length > 0;

            let winnerTeam = 'villager';

            if (executed.includes('peace') || executed.length === 0) {
                if (werewolvesExist) {
                    winnerTeam = 'werewolf';
                } else {
                    winnerTeam = 'villager';
                }
            } else {
                // 処刑されたなかに人狼が1人でもいれば市民の勝ち
                const executedAWerewolf = executed.some(name => {
                    const p = gState.activePlayers.find(x => x.name === name);
                    return p && p.currentRole === 'wolf';
                });

                if (executedAWerewolf) {
                    winnerTeam = 'villager';
                } else {
                    if (werewolvesExist) {
                        winnerTeam = 'werewolf';
                    } else {
                        winnerTeam = 'werewolf_no_wolves'; 
                    }
                }
            }

            roomData.status = 'result';
            roomData.gameState.winnerTeam = winnerTeam;
            roomData.gameState.executed = executed;
            broadcastData(roomData);
        });


        // --- 4. RESULTS DISPLAY ---
        function processResultPhase(data) {
            transitionToScreen('result');
            const gState = data.gameState;
            
            const winBanner = document.getElementById('result-winner-team');
            if (gState.winnerTeam === 'villager') {
                winBanner.innerText = '市民チームの勝利！';
                winBanner.className = 'text-3xl font-bold text-emerald-400 wolf-title tracking-wider';
            } else if (gState.winnerTeam === 'werewolf') {
                winBanner.innerText = '人狼チームの勝利！';
                winBanner.className = 'text-3xl font-bold text-red-500 wolf-title tracking-wider';
            } else {
                winBanner.innerText = '平和村の追放失敗（人狼はいませんでした）';
                winBanner.className = 'text-3xl font-bold text-amber-500 wolf-title tracking-wider';
            }

            // 処刑結果
            const execDisplay = document.getElementById('result-executed-players');
            const executed = gState.executed || [];
            if (executed.length === 0) {
                execDisplay.innerHTML = `<span class="text-emerald-400">平和村（誰も追放されませんでした）</span>`;
            } else {
                execDisplay.innerHTML = executed.map(name => {
                    if (name === 'peace') return '平和村希望';
                    const p = gState.activePlayers.find(x => x.name === name);
                    const curRoleName = p ? ALL_ROLES[p.currentRole].name : '';
                    return `<span class="text-white font-bold">${name}</span> (${curRoleName})`;
                }).join(' ＆ ');
            }

            // 役職公開
            const breakContainer = document.getElementById('result-roles-reveal');
            breakContainer.innerHTML = '';

            gState.activePlayers.forEach(p => {
                const init = ALL_ROLES[p.initialRole];
                const curr = ALL_ROLES[p.currentRole];
                const votesGot = Object.values(gState.votes || {}).filter(v => v === p.name).length;

                const div = document.createElement('div');
                div.className = 'bg-slate-950 p-3 rounded-lg border border-slate-800 flex flex-col sm:flex-row sm:items-center justify-between text-xs gap-2';
                
                let changeIndicator = '';
                if (p.initialRole !== p.currentRole) {
                    changeIndicator = `<span class="text-amber-400 font-bold ml-1">【途中で役職変動】</span>`;
                }

                div.innerHTML = `
                    <div>
                        <div class="text-sm font-bold text-white flex items-center space-x-2">
                            <span>${p.name}</span>
                            <span class="text-[10px] bg-slate-800 text-slate-400 px-2 py-0.5 rounded border border-slate-700">${votesGot} 票獲得</span>
                        </div>
                        <div class="text-slate-400 mt-1">
                            当初: <span class="text-slate-300 font-medium">${init.name}</span> ➔ 
                            最終: <span class="text-white font-bold">${curr.name}</span> ${changeIndicator}
                        </div>
                    </div>
                    <div class="text-[10px] px-2 py-1 bg-slate-900 rounded border border-slate-800 text-right text-slate-300 font-mono">
                        投票先: ${gState.votes[p.name] === 'peace' ? '平和村' : (gState.votes[p.name] || 'なし')}
                    </div>
                `;
                breakContainer.appendChild(div);
            });

            // お墓
            const talonContainer = document.getElementById('result-talon-cards');
            talonContainer.innerHTML = '';
            gState.talon.forEach((t, idx) => {
                const r = ALL_ROLES[t.role];
                const div = document.createElement('div');
                div.className = 'bg-slate-900 p-2.5 rounded border border-slate-800 text-xs text-center';
                div.innerHTML = `
                    <span class="text-slate-500 block text-[10px] mb-0.5">お墓 ${idx === 0 ? 'A' : 'B'}</span>
                    <strong class="text-slate-200 text-sm">${r.name}</strong>
                `;
                talonContainer.appendChild(div);
            });

            // 夜の行動ログ
            const logContainer = document.getElementById('result-action-log');
            logContainer.innerHTML = '';
            (gState.actionLogs || []).forEach(log => {
                const p = document.createElement('p');
                p.className = 'border-l-2 border-indigo-500/50 pl-2 py-0.5 text-left';
                p.innerText = log;
                logContainer.appendChild(p);
            });

            // 再プレイ領域
            if (isHost) {
                document.getElementById('host-restart-area').classList.remove('hidden');
                document.getElementById('guest-restart-area').classList.add('hidden');
            } else {
                document.getElementById('host-restart-area').classList.add('hidden');
                document.getElementById('guest-restart-area').classList.remove('hidden');
            }

            // 投票状態のクリアとプルダウンの有効化
            const castBtn = document.getElementById('btn-cast-vote');
            castBtn.disabled = false;
            castBtn.innerText = "投票を送信する";
            castBtn.className = "w-full py-2.5 bg-red-600 hover:bg-red-500 text-white text-xs font-bold rounded-lg transition";
            document.getElementById('my-vote-selector').disabled = false;
        }

        // ホストによるゲームの初期化再プレイ
        document.getElementById('btn-restart-game').addEventListener('click', () => {
            if (!isHost || !roomData) return;

            const nextPlayers = roomData.players.map(p => {
                return { name: p.name, peerId: p.peerId };
            });

            roomData.status = 'waiting';
            roomData.players = nextPlayers;
            roomData.gameState = {
                deck: [],
                activePlayers: [],
                talon: [],
                actionIndex: isOfflineMode ? 0 : 1,
                actionLogs: [],
                votes: {},
                timerSeconds: 300,
                timerRunning: false
            };

            broadcastData(roomData);
        });

    </script>
</body>
</html>
