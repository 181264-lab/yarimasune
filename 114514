                order: 2
            },
            robber: {
                id: 'robber',
                name: '怪盗',
                team: 'villager',
                teamName: '市民陣営',
                colorClass: 'bg-amber-900/50 text-amber-300 border-amber-700',
                icon: 'fa-mask text-amber-400',
                desc: '夜の間に自分と他の誰かのカードをすり替えることができます。すり替えた後のカードをこっそり確認します。',
                order: 3
            },
            villager: {
                id: 'villager',
                name: '市民',
                team: 'villager',
                teamName: '市民陣営',
                colorClass: 'bg-emerald-900/50 text-emerald-300 border-emerald-700',
                icon: 'fa-user text-emerald-400',
                desc: '夜の行動はありません。昼の議論において、言葉巧みな人狼をあぶり出すように推理しましょう。',
                order: 0
            },
            troublemaker: {
                id: 'troublemaker',
                name: 'トラブルメーカー',
                team: 'villager',
                teamName: '市民陣営',
                colorClass: 'bg-purple-900/50 text-purple-300 border-purple-700',
                icon: 'fa-shuffle text-purple-400',
                desc: '他のプレイヤー２人のカードをこっそり入れ替えます。ただし自分はその内容を知ることはできません。',
                order: 4
            },
            mason: {
                id: 'mason',
                name: '共同墓地（石工）',
                team: 'villager',
                teamName: '市民陣営',
                colorClass: 'bg-slate-700/50 text-slate-300 border-slate-600',
                icon: 'fa-hammer text-slate-400',
                desc: '他の「石工」が誰であるかを確認できます。（2枚セットで遊ぶことをおすすめします）',
                order: 1.5
            },
            insomniac: {
                id: 'insomniac',
                name: '不眠症',
                team: 'villager',
                teamName: '市民陣営',
                colorClass: 'bg-pink-900/50 text-pink-300 border-pink-700',
                icon: 'fa-eye text-pink-400',
                desc: '夜の最後に、自分のカードが誰かにすり替えられていないか最終確認をすることができます。',
                order: 5
            }
        };

        // 状態定義
        let myNickname = localStorage.getItem('werewolf_nickname') || '';
        let myRoomId = '';
        let isHost = false;
        let isOfflineMode = false; // オフライン（対面プレイモード）フラグ
        
        // P2P通信用の変数
        let myPeer = null;
        let hostConnection = null;       
        let guestConnections = {};       
        let roomData = null;             
        let localTimerInterval = null;

        const PEER_PREFIX = "wnwolf-p2p-v2-"; 

        // 対面プレイ(Offline)時のローカルプレイヤー初期設定
        let offlinePlayers = [
            { id: 1, name: 'プレイヤー1' },
            { id: 2, name: 'プレイヤー2' },
            { id: 3, name: 'プレイヤー3' },
            { id: 4, name: 'プレイヤー4' }
        ];

        // Canvas内WebSocketブロックエラーに対応するPeerJS公式接続設定
        const peerJsConfig = {
            host: '0.peerjs.com',
            port: 443,
            path: '/',
            secure: true,
            pingInterval: 5000,
            debug: 1,
            config: {
                iceServers: [
                    { urls: 'stun:stun.l.google.com:19302' },
                    { urls: 'stun:stun1.l.google.com:19302' }
                ]
            }
        };

        // お知らせ表示用モーダル
        function showModal(title, text) {
            document.getElementById('modal-title').querySelector('span').innerText = title;
            document.getElementById('modal-body').innerText = text;
            document.getElementById('custom-modal').classList.remove('hidden');
        }
        document.getElementById('btn-modal-close').addEventListener('click', () => {
            document.getElementById('custom-modal').classList.add('hidden');
        });

        // 画面切り替えの定義
        const screens = {
            lobby: document.getElementById('screen-lobby'),
            setup: document.getElementById('screen-setup'),
            nightTransition: document.getElementById('screen-night-transition'),
            nightAction: document.getElementById('screen-night-action'),
            discussion: document.getElementById('screen-discussion'),
            result: document.getElementById('screen-result')
        };

        function transitionToScreen(screenKey) {
            Object.keys(screens).forEach(key => {
                if (key === screenKey) {
                    screens[key].classList.remove('hidden');
                } else {
                    screens[key].classList.add('hidden');
                }
            });
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // コネクションステータス表示の変更
        function setBannerStatus(text, colorClass) {
            const banner = document.getElementById('connection-status-banner');
            banner.className = `mb-4 text-center text-xs py-1.5 px-3 rounded-lg font-bold text-white ${colorClass}`;
            banner.querySelector('span').innerText = text;
            banner.classList.remove('hidden');
        }

        function hideBanner() {
            document.getElementById('connection-status-banner').classList.add('hidden');
        }

        // 5桁の打ち込みやすい英数字コードをランダム生成
        function generateRoomCode() {
            const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
            let result = '';
            for (let i = 0; i < 5; i++) {
                result += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            return result;
        }

        // --- AUTOMATIC OFFLINE DETECTION & SWITCHING ---
        // 開発プレビュー(Canvas内など)でWebSocket接続が規制されている場合、自動的にオフラインモードへ移行する仕組み
        function activateOfflineMode() {
            isOfflineMode = true;
            isHost = true; // オフライン時は自分がホストを兼ねる
            
            // UIを対面プレイ用にアップデート
            document.getElementById('lobby-title').innerText = "対面マルチプレイ";
            document.getElementById('lobby-desc').innerText = "1台のスマートフォン・PCをみんなで順番に回しながら「ワンナイト人狼」を遊ぶことができます。";
            document.getElementById('lobby-icon').className = "fa-solid fa-mobile-screen text-6xl text-amber-500 animate-pulse";
            
            // オンライン入力を非表示、オフライン入力を表示
            document.getElementById('online-nickname-area').classList.add('hidden');
            document.getElementById('online-mode-controls').classList.add('hidden');
            
            document.getElementById('offline-setup-area').classList.remove('hidden');
            document.getElementById('offline-mode-controls').classList.remove('hidden');
            
            document.getElementById('display-offline-badge').classList.remove('hidden');
            document.getElementById('display-room-id').classList.add('hidden');
            
            renderOfflinePlayersInputs();
        }

        // 手動切り替えボタン
        document.getElementById('btn-toggle-manual-mode').addEventListener('click', () => {
            if (isOfflineMode) {
                // オンライン復帰
                isOfflineMode = false;
                document.getElementById('lobby-title').innerText = "オンラインP2Pマルチプレイ";
                document.getElementById('lobby-desc').innerText = "サーバー・データベース不要！それぞれの端末を直接繋いで、リアルタイムにゲームを遊ぶことができます。";
                document.getElementById('lobby-icon').className = "fa-solid fa-cloud-bolt text-6xl text-indigo-400 animate-bounce";
                
                document.getElementById('online-nickname-area').classList.remove('hidden');
                document.getElementById('online-mode-controls').classList.remove('hidden');
                
                document.getElementById('offline-setup-area').classList.add('hidden');
                document.getElementById('offline-mode-controls').classList.add('hidden');
                document.getElementById('display-offline-badge').classList.add('hidden');
            } else {
                activateOfflineMode();
            }
        });

        // プレビュー内（iframe内）でWebSocket制限を検知して事前対策
        window.addEventListener('load', () => {
            // iframeのセキュア制限環境下（Canvasなど）にあるかを検知する
            const inIframe = window.self !== window.top;
            if (inIframe) {
                console.warn("Canvasプレビュー環境を検出しました。対面プレイモードに初期化します。");
                activateOfflineMode();
            }
        });

        // --- オフラインモード用のプレイヤー設定 ---
        function renderOfflinePlayersInputs() {
            const container = document.getElementById('offline-players-list');
            container.innerHTML = '';
            
            offlinePlayers.forEach((p, idx) => {
                const div = document.createElement('div');
                div.className = 'flex items-center space-x-2 bg-slate-900 p-2 rounded-lg border border-slate-800';
                div.innerHTML = `
                    <span class="text-xs text-slate-500 font-bold w-5 text-center">${idx + 1}</span>
                    <input type="text" value="${p.name}" data-idx="${idx}" class="offline-name-input bg-transparent border-0 border-b border-transparent focus:border-indigo-500 focus:ring-0 text-white text-sm w-full py-0.5" placeholder="名前">
                    ${offlinePlayers.length > 3 ? `
                    <button class="btn-remove-offline text-red-500 hover:text-red-400 p-1" data-idx="${idx}">
                        <i class="fa-solid fa-trash-can text-xs"></i>
                    </button>
                    ` : ''}
                `;
                container.appendChild(div);
            });

            // バインド
            document.querySelectorAll('.offline-name-input').forEach(input => {
                input.addEventListener('change', (e) => {
                    const idx = parseInt(e.target.dataset.idx);
                    offlinePlayers[idx].name = e.target.value.trim() || `プレイヤー${idx + 1}`;
                });
            });

            document.querySelectorAll('.btn-remove-offline').forEach(btn => {
                btn.addEventListener('click', () => {
                    const idx = parseInt(btn.dataset.idx);
                    offlinePlayers.splice(idx, 1);
                    renderOfflinePlayersInputs();
                });
            });
        }

        document.getElementById('btn-add-offline-player').addEventListener('click', () => {
            if (offlinePlayers.length >= 6) {
                showModal('人数制限', '対面モードは最大6名まで登録可能です。');
                return;
            }
            offlinePlayers.push({ id: offlinePlayers.length + 1, name: `プレイヤー${offlinePlayers.length + 1}` });
            renderOfflinePlayersInputs();
        });

        // オフライン設定画面に進む
        document.getElementById('btn-start-offline-setup').addEventListener('click', () => {
            // オフライン用ルームデータの構築
            roomData = {
                id: "LOCAL",
                host: offlinePlayers[0].name,
                hostPeerId: "LOCAL",
                status: 'waiting',
                players: offlinePlayers.map(p => ({ name: p.name, peerId: `local-${p.id}` })),
                roleSelection: {
                    wolf: 1,
                    seer: 1,
                    robber: 1,
                    villager: 1,
                    troublemaker: 1,
                    mason: 0,
                    insomniac: 0
                },
                gameState: {
                    deck: [],
                    activePlayers: [],
                    talon: [],
                    actionIndex: 0,
                    actionLogs: [],
                    votes: {},
                    timerSeconds: 300,
                    timerRunning: false
                }
            };

            // 各ビューのバッジ、非表示、待機室メッセージを調整
            document.getElementById('setup-room-code-badge').className = "hidden";
            document.getElementById('setup-screen-title').innerText = "ゲーム設定";
            document.getElementById('setup-screen-desc').innerText = "使用する役職の数をプレイヤー数に合わせて調整してください。";
            
            syncScreenState(roomData);
        });


        // --- P2P データ送信ユーティリティ ---
        function broadcastData(data) {
            roomData = data;
            syncScreenState(data);
            
            // オフライン時は他デバイス送信をスキップ
            if (isOfflineMode) return;

            Object.values(guestConnections).forEach(conn => {
                if (conn && conn.open) {
                    conn.send({ type: 'SYNC_STATE', payload: data });
                }
            });
        }

        // --- 【部屋を作る】を押した時の処理 (P2P通信モード) ---
        document.getElementById('btn-create-room').addEventListener('click', () => {
            const nick = document.getElementById('input-nickname').value.trim();
            if (!nick) {
                showModal('名前の入力', 'ニックネームを入力してください。');
                return;
            }
            myNickname = nick;
            localStorage.setItem('werewolf_nickname', nick);

            const code = generateRoomCode();
            myRoomId = code;
            isHost = true;

            setBannerStatus("通信サーバーに接続しています...", "bg-blue-600");

            // WebSocket(P2P)のSecurityError・クラッシュを未然にキャッチして安全に縮退
            try {
                myPeer = new Peer(`${PEER_PREFIX}${code}`, peerJsConfig);
            } catch (initErr) {
                console.error("PeerJSのインスタンス生成に失敗:", initErr);
                handleConnectionCrash();
                return;
            }

            myPeer.on('open', (id) => {
                setBannerStatus("接続に成功しました！お友達を招待してください。", "bg-emerald-600");
                
                roomData = {
                    id: code,
                    host: myNickname,
                    hostPeerId: id,
                    status: 'waiting',
                    players: [{ name: myNickname, peerId: id }],
                    roleSelection: {
                        wolf: 1,
                        seer: 1,
                        robber: 1,
                        villager: 1,
                        troublemaker: 1,
                        mason: 0,
                        insomniac: 0
                    },
                    gameState: {
                        deck: [],
                        activePlayers: [],
                        talon: [],
                        actionIndex: 0,
                        actionLogs: [],
                        votes: {},
                        timerSeconds: 300,
                        timerRunning: false
                    }
                };

                guestConnections = {};
                syncScreenState(roomData);
            });

            myPeer.on('error', (err) => {
                console.error("PeerJSエラー:", err);
                
                // WebSocket例外、セキュリティ拒否、ポートブロッキングを検出
                if (err.type === 'socket-error' || err.type === 'network' || err.type === 'peer-api') {
                    handleConnectionCrash();
                } else if (err.type === 'unavailable-id') {
                    showModal('ルーム作成エラー', 'この部屋コードはインターネット上で他の方が使用中です。もう一度作成を試してください。');
                } else {
                    showModal('接続に失敗しました', `通信エラー: ${err.type}`);
                }
            });

            myPeer.on('connection', (conn) => {
                conn.on('open', () => {
                    guestConnections[conn.peer] = conn;
                    conn.on('data', (data) => {
                        handleClientMessage(conn.peer, data);
                    });
                });

                conn.on('close', () => {
                    delete guestConnections[conn.peer];
                    if (roomData && roomData.status === 'waiting') {
                        roomData.players = roomData.players.filter(p => p.peerId !== conn.peer);
                        broadcastData(roomData);
                    }
                });
            });
        });

        // 通信クラッシュ時（WebSocket禁止環境）のフォールバック
        function handleConnectionCrash() {
            setBannerStatus("WebSocketエラーを検出 - 対面プレイに移行しました", "bg-amber-600");
            showModal(
                '接続エラー(WebSocket制限)', 
                'お使いの開発プレビュー（Canvas）またはネットワークセキュリティにより、端末同士の接続（WebSocket）が遮断されました。\n\n【自動フォールバック】\nゲームをスムーズにテスト・体験できるよう、自動的に「1台のスマホ・PCを回して遊ぶ対面プレイモード」に切り替えました！ロビーからそのままゲーム設定を始めてください。'
            );
            activateOfflineMode();
        }

        // --- 【部屋に入る】を押した時の処理 ---
        document.getElementById('btn-join-room').addEventListener('click', () => {
            const nick = document.getElementById('input-nickname').value.trim();
            const code = document.getElementById('input-room-code').value.trim().toUpperCase();
            
            if (!nick) {
                showModal('名前の入力', 'ニックネームを入力してください。');
                return;
            }
            if (!code || code.length !== 5) {
                showModal('部屋コードの入力', '5桁の部屋コードを入力してください。');
                return;
            }

            myNickname = nick;
            localStorage.setItem('werewolf_nickname', nick);
            myRoomId = code;
            isHost = false;

            setBannerStatus("ホストを探しています...", "bg-blue-600");

            try {
                myPeer = new Peer(peerJsConfig);
            } catch (initErr) {
                console.error("PeerJSのクライアント初期化失敗:", initErr);
                handleConnectionCrash();
                return;
            }

            myPeer.on('open', (id) => {
                const targetHostPeerId = `${PEER_PREFIX}${code}`;
                hostConnection = myPeer.connect(targetHostPeerId);

                hostConnection.on('open', () => {
                    setBannerStatus("友達の部屋に接続しました！準備中...", "bg-emerald-600");
                    
                    hostConnection.send({
                        type: 'JOIN_REQ',
                        payload: { name: myNickname, peerId: id }
                    });
                });

                hostConnection.on('data', (data) => {
                    if (data.type === 'SYNC_STATE') {
                        roomData = data.payload;
                        syncScreenState(roomData);
                    } else if (data.type === 'REJECT') {
                        showModal('入れませんでした', data.payload || '部屋に入ることができませんでした。');
                        disconnectPeer();
                    }
                });

                hostConnection.on('close', () => {
                    showModal('切断されました', 'ホストとの通信が切れました。ロビーに戻ります。');
                    disconnectPeer();
                });
            });

            myPeer.on('error', (err) => {
                console.error("PeerJS接続エラー:", err);
                if (err.type === 'socket-error' || err.type === 'network') {
                    handleConnectionCrash();
                } else {
                    setBannerStatus("接続できませんでした", "bg-red-600");
                    showModal('接続失敗', '部屋が見つかりませんでした。入力した5桁の部屋コードが正しいか確認してください。');
                }
            });
        });

        // 接続リセット
        function disconnectPeer() {
            if (hostConnection) {
                hostConnection.close();
                hostConnection = null;
            }
            Object.values(guestConnections).forEach(conn => conn.close());
            guestConnections = {};

            if (myPeer) {
                myPeer.destroy();
                myPeer = null;
            }

            myRoomId = '';
            isHost = false;
            roomData = null;
            if (localTimerInterval) clearInterval(localTimerInterval);

            document.getElementById('display-room-id').classList.add('hidden');
            hideBanner();
            transitionToScreen('lobby');
        }

        document.getElementById('btn-reset').addEventListener('click', () => {
            disconnectPeer();
        });

        // クライアントからのメッセージ処理
        function handleClientMessage(senderPeerId, msg) {
            if (!isHost || !roomData || isOfflineMode) return;

            switch (msg.type) {
                case 'JOIN_REQ':
                    if (roomData.status !== 'waiting') {
                        const conn = guestConnections[senderPeerId];
                        if (conn) conn.send({ type: 'REJECT', payload: 'このゲームはすでに開始されています。' });
                        return;
                    }
                    
                    let candidateName = msg.payload.name;
                    while (roomData.players.some(p => p.name === candidateName)) {
                        candidateName += "#";
                    }

                    roomData.players.push({ name: candidateName, peerId: senderPeerId });
                    broadcastData(roomData);
                    break;

                case 'UPDATE_ROLES':
                    roomData.roleSelection = msg.payload;
                    broadcastData(roomData);
                    break;

                case 'NIGHT_ACTION_COMMIT':
                    const gStateCommit = roomData.gameState;
                    const committedPlayer = gStateCommit.activePlayers.find(p => p.name === msg.payload.playerName);
                    if (committedPlayer) {
                        committedPlayer.actionDone = true;
                    }
                    if (msg.payload.log) {
                        gStateCommit.actionLogs.push(msg.payload.log);
                    }
                    if (msg.payload.updatedPlayers) {
                        gStateCommit.activePlayers = msg.payload.updatedPlayers;
                    }
                    broadcastData(roomData);
                    break;

                case 'CAST_VOTE':
                    const vState = roomData.gameState;
                    vState.votes[msg.payload.voterName] = msg.payload.targetName;
                    broadcastData(roomData);
                    break;

                case 'TOGGLE_TIMER':
                    roomData.gameState.timerRunning = !roomData.gameState.timerRunning;
                    broadcastData(roomData);
                    break;
            }
        }

        // 状態同期
        function syncScreenState(data) {
            localRoleSelection = data.roleSelection || {};
            document.getElementById('setup-room-code').innerText = data.id;
            
            if (!isOfflineMode) {
                document.getElementById('current-room-code').innerText = data.id;
                document.getElementById('display-room-id').classList.remove('hidden');
                document.getElementById('display-offline-badge').classList.add('hidden');
            } else {
                document.getElementById('display-room-id').classList.add('hidden');
                document.getElementById('display-offline-badge').classList.remove('hidden');
            }

            switch (data.status) {
                case 'waiting':
                    setupWaitingRoom(data);
                    break;
                case 'night':
                    processNightPhase(data);
                    break;
                case 'discussion':
                    processDiscussionPhase(data);
                    break;
                case 'result':
                    processResultPhase(data);
                    break;
            }
        }

        function setupWaitingRoom(data) {
            transitionToScreen('setup');

            const container = document.getElementById('players-waiting-list');
            container.innerHTML = '';
            
            const pCount = data.players.length;
            document.getElementById('waiting-players-count').innerText = pCount;

            data.players.forEach(p => {
                const isThisMe = isOfflineMode ? false : (p.peerId === (myPeer ? myPeer.id : ''));
                const isHostPlayer = isOfflineMode ? (p.name === data.host) : (p.peerId === data.hostPeerId);
                
                const div = document.createElement('div');
                div.className = `p-3 rounded-lg border text-sm flex items-center justify-between font-bold ${
                    isThisMe ? 'bg-indigo-950/40 border-indigo-500/60 text-indigo-300' : 'bg-slate-950 border-slate-800'
                }`;
                div.innerHTML = `
                    <span class="truncate">${p.name} ${isThisMe ? ' (あなた)' : ''}</span>
                    ${isHostPlayer ? '<span class="text-[10px] bg-amber-500/20 text-amber-400 border border-amber-600/50 px-1.5 py-0.5 rounded">親</span>' : ''}
                `;
                container.appendChild(div);
            });

            if (isHost) {
                document.getElementById('host-controls-area').classList.remove('hidden');
                document.getElementById('guest-waiting-area').classList.add('hidden');
                document.getElementById('btn-start-game-text').innerText = isOfflineMode ? "対面用のゲームを始める" : "全員で夜のターンを始める";
                renderRolesConfigPanel(pCount);
            } else {
                document.getElementById('host-controls-area').classList.add('hidden');
                document.getElementById('guest-waiting-area').classList.remove('hidden');
            }
        }

        function renderRolesConfigPanel(pCount) {
            const requiredCount = pCount + 2;
            let currentSelected = 0;
            
            Object.values(localRoleSelection).forEach(v => currentSelected += v);

            document.getElementById('required-role-count').innerText = requiredCount;
            document.getElementById('selected-role-count').innerText = currentSelected;

            const grid = document.getElementById('roles-grid');
            grid.innerHTML = '';

            Object.keys(ALL_ROLES).forEach(roleId => {
                const r = ALL_ROLES[roleId];
                const count = localRoleSelection[roleId] || 0;

                const div = document.createElement('div');
                div.className = `flex flex-col justify-between p-2.5 rounded-lg border transition ${count > 0 ? 'bg-slate-800/80 border-amber-500/50' : 'bg-slate-950/40 border-slate-850'}`;
                div.innerHTML = `
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-bold text-slate-300"><i class="fa-solid ${r.icon} mr-1"></i>${r.name}</span>
                        <div class="flex items-center space-x-1.5 bg-slate-950 rounded p-0.5 border border-slate-800">
                            <button class="btn-r-dec bg-slate-800 hover:bg-slate-700 w-4 h-4 flex items-center justify-center rounded text-[10px] text-white" data-role="${roleId}">-</button>
                            <span class="text-xs font-bold px-1 text-white">${count}</span>
                            <button class="btn-r-inc bg-slate-800 hover:bg-slate-700 w-4 h-4 flex items-center justify-center rounded text-[10px] text-white" data-role="${roleId}">+</button>
                        </div>
                    </div>
                `;
                grid.appendChild(div);
            });

            document.querySelectorAll('.btn-r-inc').forEach(btn => {
                btn.onclick = () => {
                    const role = btn.dataset.role;
                    if (localRoleSelection[role] < 4) {
                        localRoleSelection[role]++;
                        roomData.roleSelection = localRoleSelection;
                        broadcastData(roomData);
                    }
                };
            });

            document.querySelectorAll('.btn-r-dec').forEach(btn => {
                btn.onclick = () => {
                    const role = btn.dataset.role;
                    if (localRoleSelection[role] > 0) {
                        localRoleSelection[role]--;
                        roomData.roleSelection = localRoleSelection;
                        broadcastData(roomData);
                    }
                };
            });

            const btnStart = document.getElementById('btn-start-game');
            const errorElement = document.getElementById('setup-error');

            if (currentSelected === requiredCount) {
                btnStart.disabled = false;
                errorElement.classList.add('hidden');
            } else {
                btnStart.disabled = true;
                errorElement.innerText = `現在: ${currentSelected}枚 (お墓含め ${requiredCount}枚必要です)`;
                errorElement.classList.remove('hidden');
            }
        }

        document.getElementById('btn-start-game').addEventListener('click', () => {
            if (!isHost || !roomData) return;

            const playersList = roomData.players;
            
            let deck = [];
            Object.keys(localRoleSelection).forEach(roleId => {
                const count = localRoleSelection[roleId];
                for (let i = 0; i < count; i++) {
                    deck.push(roleId);
                }
            });

            for (let i = deck.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [deck[i], deck[j]] = [deck[j], deck[i]];
            }

            const activePlayers = playersList.map((p, idx) => {
                return {
                    name: p.name,
                    peerId: p.peerId,
                    initialRole: deck[idx],
                    currentRole: deck[idx],
                    actionDone: false
                };
            });

            const talon = [
                { id: 'talon1', role: deck[playersList.length] },
                { id: 'talon2', role: deck[playersList.length + 1] }
            ];

            roomData.status = 'night';
            roomData.gameState = {
                deck: deck,
                activePlayers: activePlayers,
                talon: talon,
                actionIndex: isOfflineMode ? 0 : 1, // 対面時はプレイヤーインデックス(0)、オンライン時は行動順番オーダー(1)
                actionLogs: ["人狼オンライン：夜が訪れました。お互いの役職が決まります。"],
                votes: {},
                timerSeconds: 300,
                timerRunning: false
            };

            broadcastData(roomData);
        });

        // --- 2. NIGHT PHASE ACTIONS ---
        function processNightPhase(data) {
            const gState = data.gameState;

            // --- A. 対面プレイ（ローカル1台）の場合の処理 ---
            if (isOfflineMode) {
                const curPlayerIdx = gState.actionIndex;
                if (curPlayerIdx >= gState.activePlayers.length) {
                    // 全プレイヤーの役職確認と行動が完了 ➔ 朝（議論）へ
                    roomData.status = 'discussion';
                    roomData.gameState.timerSeconds = 300;
                    roomData.gameState.timerRunning = false;
                    broadcastData(roomData);
                    return;
                }

                const player = gState.activePlayers[curPlayerIdx];
                
                // 確認トランジション画面（次の人が画面を覗かないようにするためのインターバル）
                transitionToScreen('nightTransition');
                
                document.getElementById('night-title-main').innerText = "プレイヤー交代";
                document.getElementById('night-status-text').innerHTML = `
                    次は <b class="text-amber-400 font-bold text-xl">${player.name}</b> さんの番です。<br>
                    他のみんなは画面を見ないように裏返してください。
                `;
                document.getElementById('night-sub-order').innerHTML = `
                    【操作手順】<br>
                    1. ${player.name} さんにこの端末を手渡します。<br>
                    2. 準備ができたら下のボタンを押してカードを確認してください。
                `;

                // 対面用の進行ボタンを表示
                const transitionButtonArea = document.getElementById('offline-transition-button-area');
                transitionButtonArea.classList.remove('hidden');

                document.getElementById('btn-start-offline-turn').onclick = () => {
                    transitionButtonArea.classList.add('hidden');
                    renderNightActionScreen(player, data);
                };
                return;
            }

            // --- B. オンラインP2Pマルチプレイの場合の処理 ---
            const me = gState.activePlayers.find(p => p.peerId === (myPeer ? myPeer.id : ''));
            if (!me) {
                transitionToScreen('nightTransition');
                document.getElementById('night-status-text').innerText = "ただいまゲーム中です。観戦でお待ちください。";
                return;
            }

            const myInitialRole = ALL_ROLES[me.initialRole];
            const currentTurnOrder = gState.actionIndex;

            if (myInitialRole.order === currentTurnOrder && !me.actionDone) {
                renderNightActionScreen(me, data);
            } else {
                transitionToScreen('nightTransition');
                const actingRoles = Object.values(ALL_ROLES).filter(r => r.order === currentTurnOrder);
                const actingNames = actingRoles.map(r => r.name).join(' / ');
                
                document.getElementById('night-status-text').innerHTML = `
                    現在は深夜です。<br>
                    <b class="text-indigo-400 font-bold">${actingNames || '一部の役職'}</b>が行動しています。<br>
                    周りの画面を覗かないようにお待ちください。
                `;

                if (isHost) {
                    checkAndAdvanceNightPipeline(data);
                }
            }
        }

        // オンラインホスト用：夜の進行管理パイプライン
        function checkAndAdvanceNightPipeline(data) {
            if (isOfflineMode) return;
            const gState = data.gameState;
            const currentTurnOrder = gState.actionIndex;
            const playersOfThisOrder = gState.activePlayers.filter(p => ALL_ROLES[p.initialRole].order === currentTurnOrder);
            const allDone = playersOfThisOrder.every(p => p.actionDone);

            if (allDone || playersOfThisOrder.length === 0) {
                const nextOrder = currentTurnOrder + 1;
                const maxOrder = 5; 

                if (nextOrder > maxOrder) {
                    roomData.status = 'discussion';
                    roomData.gameState.timerSeconds = 300;
                    roomData.gameState.timerRunning = false;
                    broadcastData(roomData);
                } else {
                    roomData.gameState.actionIndex = nextOrder;
                    broadcastData(roomData);
                }
            }
        }

        // 夜のアクション画面の描画
        function renderNightActionScreen(myPlayerState, data) {
            const myInitialRole = ALL_ROLES[myPlayerState.initialRole];

            document.getElementById('action-player-title').innerText = myPlayerState.name;
            document.getElementById('card-role-name').innerText = myInitialRole.name;
            document.getElementById('card-role-team').innerText = myInitialRole.teamName;
            document.getElementById('card-role-desc').innerText = myInitialRole.desc;

            const cardDisplay = document.getElementById('card-display');
            cardDisplay.className = `w-44 h-60 rounded-2xl border-2 flex flex-col items-center justify-center p-4 text-center shadow-xl relative overflow-hidden ${myInitialRole.colorClass}`;
            document.getElementById('card-icon').innerHTML = `<i class="fa-solid ${myInitialRole.icon}"></i>`;

            const teamLabel = document.getElementById('card-role-team');
            if (myInitialRole.team === 'werewolf') {
                teamLabel.className = 'text-[10px] font-bold mt-1 px-2.5 py-0.5 rounded-full bg-red-900 text-red-200 border border-red-600';
            } else {
                teamLabel.className = 'text-[10px] font-bold mt-1 px-2.5 py-0.5 rounded-full bg-slate-800 text-slate-200 border border-slate-600';
            }

            setupActionInteractions(myPlayerState, data);
            transitionToScreen('nightAction');
        }

        // 各役職ごとの選択肢生成・実行
        function setupActionInteractions(me, data) {
            const controls = document.getElementById('action-controls');
            const resultText = document.getElementById('action-result-text');
            const promptTitle = document.getElementById('action-prompt-title');
            
            controls.innerHTML = '';
            resultText.innerText = '';
            resultText.classList.add('hidden');

            const otherPlayers = data.gameState.activePlayers.filter(p => p.name !== me.name);
            const roleId = me.initialRole;

            const btnComplete = document.getElementById('btn-complete-action');
            btnComplete.disabled = true;
            btnComplete.classList.add('opacity-40');

            // 完了ボタンに文言調整（対面の場合は端末を伏せるようガイド）
            btnComplete.innerText = isOfflineMode ? "確認完了（画面を隠す）" : "行動を完了して他の人を待つ";

            function commitNightAction(actionPayload) {
                if (isHost || isOfflineMode) {
                    const gState = roomData.gameState;
                    const committedPlayer = gState.activePlayers.find(p => p.name === me.name);
                    if (committedPlayer) {
                        committedPlayer.actionDone = true;
                    }
                    if (actionPayload.log) {
                        gState.actionLogs.push(actionPayload.log);
                    }
                    if (actionPayload.updatedPlayers) {
                        gState.activePlayers = actionPayload.updatedPlayers;
                    }
                    
                    if (isOfflineMode) {
                        // 次のオフラインプレイヤー確認用のトリガー設定
                        btnComplete.onclick = () => {
                            roomData.gameState.actionIndex++;
                            broadcastData(roomData);
                        };
                    } else {
                        broadcastData(roomData);
                    }
                } else {
                    hostConnection.send({
                        type: 'NIGHT_ACTION_COMMIT',
                        payload: {
                            playerName: me.name,
                            log: actionPayload.log,
                            updatedPlayers: actionPayload.updatedPlayers
                        }
                    });
                }
                btnComplete.disabled = false;
                btnComplete.classList.remove('opacity-40');
            }

            switch (roleId) {
                case 'wolf':
                    promptTitle.innerText = '仲間の人狼の確認';
                    const otherWolves = otherPlayers.filter(p => p.initialRole === 'wolf');
                    if (otherWolves.length > 0) {
                        const wolfNames = otherWolves.map(w => w.name).join('、');
                        resultText.innerText = `仲間の人狼は 【 ${wolfNames} 】 さんです。仲間と協力して勝利を目指しましょう！`;
                        resultText.classList.remove('hidden');
                        commitNightAction({ log: `${me.name} が仲間の人狼の存在を確認しました。` });
                    } else {
                        resultText.innerText = `仲間はいません（単独人狼です）。お墓（余っているカード）のどちらか1枚をタップして覗けます。`;
                        resultText.classList.remove('hidden');

                        const div = document.createElement('div');
                        div.className = 'grid grid-cols-2 gap-2 mt-1';
                        div.innerHTML = `
                            <button id="btn-peek-t1" class="bg-indigo-900/40 hover:bg-indigo-800 border border-indigo-700 p-2.5 rounded-lg text-xs font-bold transition">お墓 A を覗く</button>
                            <button id="btn-peek-t2" class="bg-indigo-900/40 hover:bg-indigo-800 border border-indigo-700 p-2.5 rounded-lg text-xs font-bold transition">お墓 B を覗く</button>
                        `;
                        controls.appendChild(div);

                        document.getElementById('btn-peek-t1').addEventListener('click', () => {
                            const ref = ALL_ROLES[data.gameState.talon[0].role];
                            resultText.innerText = `お墓 A の役職は 【 ${ref.name} 】 でした。`;
                            disableButtons(['btn-peek-t1', 'btn-peek-t2']);
                            commitNightAction({ log: `${me.name} が単独人狼の能力でお墓Aを確認しました。` });
                        });

                        document.getElementById('btn-peek-t2').addEventListener('click', () => {
                            const ref = ALL_ROLES[data.gameState.talon[1].role];
                            resultText.innerText = `お墓 B の役職は 【 ${ref.name} 】 でした。`;
                            disableButtons(['btn-peek-t1', 'btn-peek-t2']);
                            commitNightAction({ log: `${me.name} が単独人狼の能力でお墓Bを確認しました。` });
                        });
                    }
                    break;

                case 'seer':
                    promptTitle.innerText = '占う対象を1つ選んでください';
                    
                    const optionDiv = document.createElement('div');
                    optionDiv.className = 'space-y-3';
                    
                    let pSelect = `<p class="text-[10px] text-slate-400">プラン①：誰か1人の元の役職を見る</p><div class="grid grid-cols-2 gap-2">`;
                    otherPlayers.forEach(p => {
                        pSelect += `
                            <button class="btn-seer-p bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded border border-slate-700 transition" data-target="${p.name}">
                                ${p.name}
                            </button>
                        `;
                    });
                    pSelect += `</div>`;

                    let tSelect = `
                        <p class="text-[10px] text-slate-400 pt-1">プラン②：お墓（残り2枚）の役職を両方見る</p>
                        <button id="btn-seer-t" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded border border-slate-700 transition">
                            お墓（残りの2枚）を両方占う
                        </button>
                    `;

                    optionDiv.innerHTML = pSelect + tSelect;
                    controls.appendChild(optionDiv);

                    document.querySelectorAll('.btn-seer-p').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            const target = e.target.dataset.target;
                            const targetPlayer = data.gameState.activePlayers.find(p => p.name === target);
                            const role = ALL_ROLES[targetPlayer.initialRole];

                            resultText.innerText = `${target} さんの最初の役職は 【 ${role.name} 】 でした。`;
                            resultText.classList.remove('hidden');
                            
                            disableButtons(['btn-seer-t', ...document.querySelectorAll('.btn-seer-p')]);
                            commitNightAction({ log: `${me.name} が占い師の能力で ${target} を占い、${role.name} であることを確認しました。` });
                        });
                    });

                    document.getElementById('btn-seer-t').addEventListener('click', () => {
                        const rA = ALL_ROLES[data.gameState.talon[0].role].name;
                        const rB = ALL_ROLES[data.gameState.talon[1].role].name;

                        resultText.innerText = `お墓のカードは 【 A: ${rA} 】 ＆ 【 B: ${rB} 】 でした。`;
                        resultText.classList.remove('hidden');

                        disableButtons(['btn-seer-t', ...document.querySelectorAll('.btn-seer-p')]);
                        commitNightAction({ log: `${me.name} が占い師の能力でお墓の2枚（${rA}, ${rB}）を確認しました。` });
                    });
                    break;

                case 'robber':
                    promptTitle.innerText = 'すり替えたい相手を選んでください';
                    
                    const robDiv = document.createElement('div');
                    robDiv.className = 'grid grid-cols-2 gap-2';
                    otherPlayers.forEach(p => {
                        robDiv.innerHTML += `
                            <button class="btn-rob bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded border border-slate-700 transition" data-target="${p.name}">
                                ${p.name}
                            </button>
                        `;
                    });
                    robDiv.innerHTML += `
                        <button id="btn-rob-skip" class="w-full bg-slate-900 text-slate-400 text-xs py-2 rounded border border-slate-850 transition col-span-full italic">
                            すり替えない
                        </button>
                    `;
                    controls.appendChild(robDiv);

                    document.querySelectorAll('.btn-rob').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            const target = e.target.dataset.target;
                            const currentPlayers = [...data.gameState.activePlayers];
                            
                            const myIdx = currentPlayers.findIndex(p => p.name === me.name);
                            const tarIdx = currentPlayers.findIndex(p => p.name === target);

                            const temp = currentPlayers[myIdx].currentRole;
                            currentPlayers[myIdx].currentRole = currentPlayers[tarIdx].currentRole;
                            currentPlayers[tarIdx].currentRole = temp;

                            const gotRole = ALL_ROLES[currentPlayers[myIdx].currentRole];
                            resultText.innerText = `${target} さんのカードを奪い、交換しました！あなたの新しい役職は 【 ${gotRole.name} 】 です。`;
                            resultText.classList.remove('hidden');

                            disableButtons(['btn-rob-skip', ...document.querySelectorAll('.btn-rob')]);
                            commitNightAction({
                                updatedPlayers: currentPlayers,
                                log: `${me.name} が怪盗の能力で ${target} のカードをすり替え、自分は ${gotRole.name} になりました。`
                            });
                        });
                    });

                    document.getElementById('btn-rob-skip').addEventListener('click', () => {
                        resultText.innerText = `交換を行いませんでした。`;
                        resultText.classList.remove('hidden');
                        disableButtons(['btn-rob-skip', ...document.querySelectorAll('.btn-rob')]);
                        commitNightAction({ log: `${me.name} は怪盗の能力を使用しませんでした。` });
                    });
                    break;

                case 'troublemaker':
                    promptTitle.innerText = '入れ替える2人を選択してください';
                    resultText.innerText = 'あなた以外の2名を選んで入れ替えます。';
                    resultText.classList.remove('hidden');

                    let selected = [];
                    const trbDiv = document.createElement('div');
                    trbDiv.className = 'grid grid-cols-2 gap-2';
                    
                    otherPlayers.forEach(p => {
                        trbDiv.innerHTML += `
                            <button class="btn-trb bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded border border-slate-700 transition" data-target="${p.name}">
                                ${p.name}
                            </button>
                        `;
                    });
                    trbDiv.innerHTML += `
                        <button id="btn-trb-skip" class="w-full bg-slate-900 text-slate-400 text-xs py-2 rounded border border-slate-850 transition col-span-full italic">
                            入れ替えない
                        </button>
                    `;
                    controls.appendChild(trbDiv);

                    document.querySelectorAll('.btn-trb').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            const target = e.target.dataset.target;
                            
                            if (selected.includes(target)) {
                                selected = selected.filter(x => x !== target);
                                e.target.className = "bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs py-2 rounded border border-slate-700 transition";
                            } else {
                                if (selected.length < 2) {
                                    selected.push(target);
                                    e.target.className = "bg-amber-900/40 text-amber-300 text-xs py-2 rounded border border-amber-600 transition font-bold";
                                }
                            }

                            if (selected.length === 2) {
                                disableButtons(['btn-trb-skip', ...document.querySelectorAll('.btn-trb')]);
                                const currentPlayers = [...data.gameState.activePlayers];
                                
                                const idx1 = currentPlayers.findIndex(p => p.name === selected[0]);
                                const idx2 = currentPlayers.findIndex(p => p.name === selected[1]);

                                const temp = currentPlayers[idx1].currentRole;
                                currentPlayers[idx1].currentRole = currentPlayers[idx2].currentRole;
                                currentPlayers[idx2].currentRole = temp;

                                resultText.innerText = `【 ${selected[0]} 】 さんと 【 ${selected[1]} 】 さんの役職カードを密かに入れ替えました。`;
                                commitNightAction({
                                    updatedPlayers: currentPlayers,
                                    log: `${me.name} がトラブルメーカーの能力で、${selected[0]} と ${selected[1]} のカードを入れ替えました。`
