<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ワンナイト人狼オンラインマルチプレイヤー (P2P通信版)</title>
    <!-- Tailwind CSS for elegant styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- PeerJS for Firebase-free Peer-to-Peer communication -->
    <script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Yusei+Magic&family=Zen+Maru+Gothic:wght@400;700&display=swap');
        body {
            font-family: 'Zen Maru Gothic', sans-serif;
            background-color: #0f172a;
            color: #f1f5f9;
        }
        .wolf-title {
            font-family: 'Yusei Magic', sans-serif;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between">

    <!-- Header -->
    <header class="bg-slate-900 border-b border-red-900/40 p-4 sticky top-0 z-50">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <i class="fa-solid fa-wolf-pack-battalion text-red-600 text-2xl animate-pulse"></i>
                <h1 class="text-xl md:text-2xl font-bold tracking-wider text-red-500 wolf-title">ワンナイト人狼 Online</h1>
            </div>
            <div class="flex items-center space-x-2">
                <span id="display-room-id" class="hidden bg-slate-800 text-amber-400 text-xs px-2.5 py-1.5 rounded-lg border border-slate-700 font-bold">
                    部屋: <span id="current-room-code" class="text-white tracking-widest ml-1">-----</span>
                </span>
                <span id="display-offline-badge" class="hidden bg-amber-950 text-amber-400 text-xs px-2.5 py-1.5 rounded-lg border border-amber-800 font-bold">
                    <i class="fa-solid fa-mobile-screen mr-1"></i>対面プレイ
                </span>
                <button id="btn-reset" class="bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs px-3 py-1.5 rounded-lg border border-slate-700 transition">
                    <i class="fa-solid fa-house mr-1"></i>ロビーへ
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content Container -->
    <main class="flex-grow max-w-2xl w-full mx-auto p-4 flex flex-col justify-center">

        <!-- Connection Status Banner -->
        <div id="connection-status-banner" class="mb-4 text-center text-xs py-1.5 px-3 rounded-lg hidden">
            <span>ステータス: 接続中...</span>
        </div>

        <!-- 0. LOBBY SCREEN (ロビー画面) -->
        <section id="screen-lobby" class="bg-slate-900/80 backdrop-blur-md p-6 rounded-2xl border border-slate-800 shadow-2xl space-y-6">
            <div class="text-center space-y-3 py-4">
                <i class="fa-solid fa-cloud-bolt text-6xl text-indigo-400 animate-bounce" id="lobby-icon"></i>
                <h2 class="text-3xl font-bold text-red-400 wolf-title tracking-wider" id="lobby-title">オンラインP2Pマルチプレイ</h2>
                <p class="text-sm text-slate-400" id="lobby-desc">サーバーレス接続！それぞれの端末を直接繋いで、リアルタイムにゲームを遊ぶことができます。</p>
            </div>

            <!-- Set Nickname / Player Setup -->
            <div class="space-y-4 bg-slate-950/60 p-4 rounded-xl border border-slate-850">
                <!-- Offline Player list input (Hidden by default, shown in offline mode) -->
                <div id="offline-setup-area" class="hidden space-y-3">
                    <label class="block text-xs font-bold text-slate-400 tracking-wider">プレイヤー登録 (3〜6人)</label>
                    <div id="offline-players-list" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <!-- Dynamic offline players inputs -->
                    </div>
                    <button id="btn-add-offline-player" class="text-xs text-indigo-400 hover:text-indigo-300 flex items-center space-x-1">
                        <i class="fa-solid fa-circle-plus"></i> <span>プレイヤーを追加</span>
                    </button>
                </div>

                <!-- Online Single Nickname input -->
                <div id="online-nickname-area" class="space-y-2">
                    <label class="block text-xs font-bold text-slate-400 tracking-wider">あなたのニックネーム</label>
                    <input type="text" id="input-nickname" class="w-full bg-slate-900 border border-slate-700 rounded-lg py-2.5 px-3 text-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm font-bold" placeholder="名前を入力してください">
                </div>
            </div>

            <!-- Online Mode Controls -->
            <div id="online-mode-controls" class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
                <!-- Create Room -->
                <div class="bg-slate-950/40 p-4 rounded-xl border border-slate-800 flex flex-col justify-between space-y-3">
                    <div>
                        <h3 class="font-bold text-white text-sm">新しく部屋を作る</h3>
                        <p class="text-xs text-slate-500 mt-1">あなたがホスト（部屋の親）になり、お友達を5桁の部屋コードで招待します。</p>
                    </div>
                    <button id="btn-create-room" class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-lg transition text-sm">
                        部屋を作成する
                    </button>
                </div>

                <!-- Join Room -->
                <div class="bg-slate-950/40 p-4 rounded-xl border border-slate-800 flex flex-col justify-between space-y-3">
                    <div>
                        <h3 class="font-bold text-white text-sm">すでにある部屋に入る</h3>
                        <p class="text-xs text-slate-500 mt-1">友達が作った部屋の「5桁の部屋コード」を入力してください。</p>
                    </div>
                    <div class="flex space-x-2">
                        <input type="text" id="input-room-code" maxlength="5" class="w-1/2 bg-slate-900 border border-slate-700 rounded-lg text-center font-mono text-lg font-bold tracking-widest text-amber-400 uppercase" placeholder="ABC12">
                        <button id="btn-join-room" class="w-1/2 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-lg transition text-sm">
                            部屋に入る
                        </button>
                    </div>
                </div>
            </div>

            <!-- Offline Mode Controls -->
            <div id="offline-mode-controls" class="hidden pt-2">
                <button id="btn-start-offline-setup" class="w-full py-4 bg-gradient-to-r from-amber-600 to-red-600 hover:from-amber-500 hover:to-red-500 text-white font-bold rounded-xl shadow-lg transition transform active:scale-95 text-lg flex justify-center items-center space-x-2">
                    <i class="fa-solid fa-gamepad"></i> <span>ゲーム設定に進む (対面プレイ)</span>
                </button>
            </div>

            <!-- Toggle Mode Manual Button -->
            <div class="text-center pt-2">
                <button id="btn-toggle-manual-mode" class="text-xs text-slate-500 hover:text-slate-300 underline transition">
                    対面プレイ（1台のスマホを回して遊ぶ）に変更する
                </button>
            </div>

            <!-- Connection Guide Banner -->
            <div id="connection-guide-banner" class="p-3 bg-slate-950/60 rounded-xl border border-slate-850 text-[11px] text-slate-400 space-y-1">
                <p class="font-bold text-amber-500 flex items-center">
                    <i class="fa-solid fa-wifi mr-1"></i> Canvas プレビュー環境での制限について
                </p>
                <p>
                    このCanvas（開発プレビュー）環境はセキュリティポリシー上、外部とのWebSocket（P2Pマルチプレイ）が制限されています。
                    <b>自動的にローカル対面モードが適用されます。</b>
                    このファイルを「ローカルPCでダブルクリックして開く」か、「GitHub Pagesに公開」すると、本来のP2Pマルチプレイが自動的に機能します！
                </p>
            </div>
        </section>

        <!-- 1. WAITING ROOM / SETUP SCREEN (待機室・設定画面) -->
        <section id="screen-setup" class="hidden bg-slate-900/80 backdrop-blur-md p-6 rounded-2xl border border-slate-800 shadow-2xl space-y-6">
            <div class="text-center space-y-1">
                <span id="setup-room-code-badge" class="text-xs bg-slate-800 text-slate-400 px-3 py-1 rounded-full border border-slate-750 font-mono tracking-widest">
                    ROOM CODE: <b id="setup-room-code" class="text-amber-400">-----</b>
                </span>
                <h2 class="text-2xl font-bold text-red-400 wolf-title pt-3" id="setup-screen-title">ゲーム待機室</h2>
                <p class="text-xs text-slate-400" id="setup-screen-desc">友達が参加するのを待ちましょう。ホストが役職を設定してゲームを開始します。</p>
            </div>

            <!-- Players List in Room -->
            <div class="space-y-3">
                <label class="block text-sm font-bold text-slate-300">
                    <i class="fa-solid fa-users text-indigo-400 mr-1"></i>参加プレイヤー (<span id="waiting-players-count">0</span>名)
                </label>
                <div id="players-waiting-list" class="grid grid-cols-2 gap-2">
                    <!-- Dynamic player labels -->
                </div>
            </div>

            <!-- Roles Selection (Only visible/editable by Host / Always visible in Offline) -->
            <div id="host-controls-area" class="space-y-4 pt-2 border-t border-slate-800 hidden">
                <div class="flex justify-between items-center">
                    <label class="block text-sm font-bold text-slate-300">
                        <i class="fa-solid fa-id-card text-yellow-500 mr-1"></i>役職の設定
                    </label>
                    <span id="role-counter" class="text-xs bg-slate-800 px-2.5 py-1 rounded-full border border-slate-700">
                        選択中: <span id="selected-role-count" class="font-bold text-yellow-400">0</span> / 必要数: <span id="required-role-count" class="font-bold text-slate-300">0</span>
                    </span>
                </div>
                
                <div class="grid grid-cols-2 gap-3" id="roles-grid">
                    <!-- Roles will be inserted dynamically -->
                </div>
                <p class="text-[11px] text-slate-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-1"></i>役職の合計枚数は <b>プレイヤー人数 ＋ 2枚</b>（場に残るカード）にする必要があります。
                </p>

                <!-- Start Button (Host/Offline) -->
                <div class="pt-2">
                    <button id="btn-start-game" class="w-full py-4 bg-gradient-to-r from-red-600 to-amber-600 hover:from-red-500 hover:to-amber-500 text-white font-bold rounded-xl shadow-lg transition duration-200 transform active:scale-95 text-lg flex justify-center items-center space-x-2 disabled:opacity-50 disabled:pointer-events-none">
                        <i class="fa-solid fa-moon"></i> <span id="btn-start-game-text">全員で夜のターンを始める</span>
                    </button>
                    <p id="setup-error" class="text-red-400 text-xs text-center mt-2 hidden"></p>
                </div>
            </div>

            <!-- Guest Waiting Message -->
            <div id="guest-waiting-area" class="p-4 bg-slate-950/60 rounded-xl text-center border border-slate-850 text-sm text-slate-400 space-y-2">
                <div class="flex items-center justify-center space-x-2">
                    <i class="fa-solid fa-spinner animate-spin text-indigo-400"></i>
                    <span>ホストがゲームを開始するのを待っています...</span>
                </div>
                <p class="text-xs text-slate-500">※開始前にホストが現在の参加人数に合わせた役職の調整を行います。</p>
            </div>
        </section>

        <!-- 2. NIGHT TURN OVERVIEW (夜のターン・待機状態または行動ターン / 対面の場合は確認画面) -->
        <section id="screen-night-transition" class="hidden bg-slate-900/90 p-8 rounded-2xl border border-slate-800 shadow-2xl text-center space-y-6">
            <div id="night-waiting-others" class="space-y-4 py-8">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-slate-800/80 rounded-full border border-indigo-500/30 mb-2 relative" id="night-icon-wrapper">
                    <i class="fa-solid fa-moon text-indigo-400 text-4xl animate-pulse"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-200 wolf-title" id="night-title-main">真夜中の時間...</h2>
                <p class="text-sm text-slate-400" id="night-status-text">他のプレイヤーが行動を選択しています。<br>画面を隠して静かにお待ちください。</p>
                <div class="p-3 bg-slate-950/40 rounded-lg text-xs text-slate-500 max-w-xs mx-auto" id="night-sub-order">
                    現在の行動順： 人狼 ➔ 占い師 ➔ 怪盗 ➔ トラブルメーカー ➔ 不眠症
                </div>
                
                <!-- Step button for offline/pass-around playing -->
                <div id="offline-transition-button-area" class="hidden pt-4">
                    <button id="btn-start-offline-turn" class="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl shadow-lg transition transform active:scale-95 text-lg">
                        準備完了（自分の役職を確認する）
                    </button>
                </div>
            </div>
        </section>

        <!-- 3. ACTION SCREEN (各個人の夜の行動・カード確認) -->
        <section id="screen-night-action" class="hidden bg-slate-900/90 p-6 rounded-2xl border border-slate-800 shadow-2xl space-y-6">
            <div class="flex justify-between items-center border-b border-slate-800 pb-3">
                <span class="text-slate-400 text-xs">あなたの番です: <b class="text-white" id="action-player-title">---</b></span>
                <span class="px-2.5 py-1 text-xs font-bold rounded-full bg-indigo-900/50 text-indigo-300 border border-indigo-700/50">あなたの夜の行動</span>
            </div>

            <!-- Card Flip Area -->
            <div class="flex flex-col items-center justify-center py-2">
                <div id="card-display" class="w-44 h-60 bg-slate-950 rounded-2xl border-2 flex flex-col items-center justify-center p-4 text-center shadow-xl relative overflow-hidden">
                    <div class="absolute inset-0 bg-radial-gradient from-transparent to-slate-950 opacity-50"></div>
                    <div id="card-icon" class="text-4xl text-amber-500 mb-3 z-10">
                        <i class="fa-solid fa-wolf-pack-battalion"></i>
                    </div>
                    <div id="card-role-name" class="text-xl font-bold text-white wolf-title tracking-wider z-10">役職名</div>
                    <div id="card-role-team" class="text-[10px] font-bold mt-1 px-2.5 py-0.5 rounded-full z-10">陣営</div>
                    <p id="card-role-desc" class="text-[11px] text-slate-400 mt-3 leading-relaxed z-10">役職の説明文がここに入ります。</p>
                </div>
            </div>

            <!-- Action Prompt & Form (Dynamic per role) -->
            <div id="action-interactive-area" class="bg-slate-950/60 p-4 rounded-xl border border-slate-800 space-y-3">
                <h4 class="font-bold text-xs text-slate-300" id="action-prompt-title">夜の能力を実行してください</h4>
                <div id="action-controls" class="space-y-2">
                    <!-- Target selectors will appear here -->
                </div>
                <div id="action-result-text" class="text-xs text-amber-400 font-bold hidden bg-amber-950/20 p-3 rounded-lg border border-amber-900/30">
                    <!-- Action results shown here immediately if applicable -->
                </div>
            </div>

            <!-- Next Confirm Button -->
            <button id="btn-complete-action" class="w-full py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl shadow-lg transition transform active:scale-95 text-md">
                行動を完了して他の人を待つ
            </button>
        </section>

        <!-- 4. TALK TIME & VOTING (議論と投票) -->
        <section id="screen-discussion" class="hidden bg-slate-900/90 p-6 rounded-2xl border border-slate-800 shadow-2xl space-y-6">
            <div class="text-center space-y-2">
                <h2 class="text-2xl font-bold text-amber-500 wolf-title flex justify-center items-center">
                    <i class="fa-solid fa-sun mr-2 animate-spin text-amber-400" style="animation-duration: 15s;"></i> 朝が来ました！
                </h2>
                <p class="text-xs text-slate-400">話し合いを行い、誰が人狼なのかを推理しましょう。</p>
            </div>

            <!-- Timer Area -->
            <div class="bg-slate-950/80 p-4 rounded-xl border border-slate-800 text-center space-y-2">
                <div class="text-3xl font-mono font-bold text-white tracking-widest" id="discussion-timer">05:00</div>
                <div id="timer-host-controls" class="flex justify-center space-x-2 hidden">
                    <button id="btn-timer-toggle" class="bg-indigo-600 hover:bg-indigo-500 text-white text-[10px] px-3 py-1.5 rounded-lg font-bold transition">
                        <i class="fa-solid fa-play mr-1"></i>スタート / 一時停止
                    </button>
                </div>
                <div id="timer-guest-status" class="text-[10px] text-slate-500">
                    （議論時間はホストが管理・同期します）
                </div>
            </div>

            <!-- Voting Section -->
            <div class="space-y-4 pt-2">
                <h3 class="font-bold text-sm text-slate-300 border-b border-slate-800 pb-2 flex items-center justify-between">
                    <span><i class="fa-solid fa-check-to-slot text-red-500 mr-1"></i>投票をおこなう</span>
                    <span class="text-xs text-slate-400" id="vote-count-status">未投票: 0人</span>
                </h3>
                
                <!-- Online voting block -->
                <div id="online-voting-input-area" class="bg-slate-950 p-4 rounded-xl border border-slate-800 space-y-3">
                    <label class="block text-xs font-bold text-slate-400">あなたの投票先：</label>
                    <select id="my-vote-selector" class="w-full bg-slate-900 border border-slate-700 rounded-lg text-sm py-2 px-3 text-white focus:ring-2 focus:ring-red-500 focus:border-red-500">
                        <!-- Target options dynamically filled -->
                    </select>
                    <button id="btn-cast-vote" class="w-full py-2.5 bg-red-600 hover:bg-red-500 text-white text-xs font-bold rounded-lg transition">
                        投票を送信する
                    </button>
                </div>

                <!-- Offline voting block (List of select boxes for pass-around play) -->
                <div id="offline-voting-inputs-area" class="space-y-3 hidden">
                    <!-- Dynamic select lists for all offline players -->
                </div>

                <div class="p-3 bg-slate-950/40 rounded-lg border border-slate-850" id="vote-badges-outer">
                    <h4 class="text-[10px] font-bold text-slate-500 mb-1.5">投票状況</h4>
                    <div id="vote-status-badges" class="flex flex-wrap gap-1.5">
                        <!-- Badges showing who voted -->
                    </div>
                </div>

                <button id="btn-reveal-results-manual" class="w-full py-4 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-bold rounded-xl shadow-lg transition transform active:scale-95 text-md hidden">
                    集計して結果を発表する
                </button>
            </div>
        </section>

        <!-- 5. RESULT SCREEN (結果発表) -->
        <section id="screen-result" class="hidden bg-slate-900/90 p-6 rounded-2xl border border-slate-800 shadow-2xl space-y-6">
            <div class="text-center space-y-2">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-red-950/50 rounded-full border border-red-500 mb-2">
                    <i class="fa-solid fa-door-open text-amber-500 text-2xl"></i>
                </div>
                <h2 class="text-3xl font-bold wolf-title tracking-wider" id="result-winner-team">---</h2>
                <p class="text-xs text-slate-400">今回のゲーム結果と、それぞれが迎えた最終的な正体です。</p>
            </div>

            <!-- Execution Result -->
            <div class="bg-slate-950/60 p-4 rounded-xl border border-slate-800 space-y-1">
                <h3 class="text-xs font-bold text-slate-400">追放された（村から送り出された）プレイヤー</h3>
                <div class="text-lg font-bold text-red-400" id="result-executed-players">---</div>
            </div>

            <!-- Roles Reveal List -->
            <div class="space-y-3">
                <h3 class="font-bold text-sm text-slate-300 border-b border-slate-800 pb-2"><i class="fa-solid fa-eye text-indigo-400 mr-1"></i>最終的な役職の内訳</h3>
                <div class="grid grid-cols-1 gap-2" id="result-roles-reveal">
                    <!-- Players real roles and original roles -->
                </div>
                
                <div class="mt-4 p-4 bg-slate-950/60 rounded-xl border border-slate-800 space-y-2">
                    <h4 class="text-xs font-bold text-slate-400">お墓・場に残ったカード</h4>
                    <div id="result-talon-cards" class="grid grid-cols-2 gap-2">
                        <!-- Leftover card info -->
                    </div>
                </div>
            </div>

            <!-- Actions Log -->
            <div class="space-y-2">
                <h3 class="font-bold text-sm text-slate-300 border-b border-slate-800 pb-2"><i class="fa-solid fa-receipt text-amber-500 mr-1"></i>夜の行動ログ</h3>
                <div id="result-action-log" class="text-[11px] text-slate-400 space-y-1 bg-slate-950/40 p-3 rounded-lg border border-slate-800 max-h-32 overflow-y-auto">
                    <!-- Actions printed here -->
                </div>
            </div>

            <!-- Reset Button (Only Host/Local can trigger next round) -->
            <div id="host-restart-area" class="hidden">
                <button id="btn-restart-game" class="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl shadow-lg transition transform active:scale-95 text-md">
                    同じメンバーで新しく始める
                </button>
            </div>
            <div id="guest-restart-area" class="text-xs text-center text-slate-500 p-3 bg-slate-950/30 rounded-lg">
                ホストが次のゲームを新しく開始するのをお待ちください...
            </div>
        </section>

    </main>

    <!-- Footer -->
    <footer class="bg-slate-950 p-4 text-center text-xs text-slate-500 border-t border-slate-900">
        <p>© 2026 ワンナイト人狼オンラインマルチプレイヤー (P2P通信版). All Rights Reserved.</p>
    </footer>

    <!-- Description Dialog Custom (No browser alerts allowed) -->
    <div id="custom-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70 backdrop-blur-sm hidden">
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 max-w-sm w-full space-y-4 shadow-2xl">
            <h3 class="text-lg font-bold text-white flex items-center space-x-2" id="modal-title">
                <i class="fa-solid fa-circle-exclamation text-amber-500"></i> <span>確認</span>
            </h3>
            <p class="text-sm text-slate-300 leading-relaxed whitespace-pre-line text-left" id="modal-body">メッセージがここに入ります。</p>
            <div class="flex justify-end pt-2">
                <button id="btn-modal-close" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-bold transition">
                    了解
                </button>
            </div>
        </div>
    </div>

    <!-- Javascript Logical Core (PeerJS P2P engine with local fallbacks) -->
    <script>
        // --- GAME STORES & SETTINGS ---
        const ALL_ROLES = {
            wolf: {
                id: 'wolf',
                name: '人狼',
